From: Hermes-Agent-Portable patch
Subject: [PATCH] hermes_cli/pty_bridge: fix Windows compatibility (fcntl import)

Upstream pty_bridge.py directly imports fcntl/termios/select at the
module level without try/except, causing ModuleNotFoundError on native
Windows. This patch wraps those imports and guards resize()/close()
calls so the module loads on Windows (PTY remains unavailable, which is
the expected behavior per the design doc).

--- a/hermes_cli/pty_bridge.py
+++ b/hermes_cli/pty_bridge.py
@@ -26,16 +26,29 @@ Design constraints:
 from __future__ import annotations
 
 import errno
-import fcntl
 import os
-import select
-import signal
 import struct
 import sys
-import termios
 import time
 from typing import Optional, Sequence
 
+try:
+    import fcntl
+except ImportError:  # pragma: no cover - Windows has no fcntl
+    fcntl = None  # type: ignore
+
+try:
+    import termios
+except ImportError:  # pragma: no cover - Windows has no termios
+    termios = None  # type: ignore
+
+try:
+    import select
+except ImportError:  # pragma: no cover - unlikely, but be safe
+    select = None  # type: ignore
+
+import signal
+
 try:
     import ptyprocess  # type: ignore
     _PTY_AVAILABLE = not sys.platform.startswith("win")
@@ -184,6 +197,8 @@ class PtyBridge:
         """Forward a terminal resize to the child via ``TIOCSWINSZ``."""
         if self._closed:
             return
+        if fcntl is None or termios is None:
+            return
         # struct winsize: rows, cols, xpixel, ypixel (all unsigned short)
         winsize = struct.pack("HHHH", max(1, rows), max(1, cols), 0, 0)
         try:
@@ -205,7 +220,13 @@ class PtyBridge:
 
         # SIGHUP is the conventional "your terminal went away" signal.
         # We escalate if the child ignores it.
-        for sig in (signal.SIGHUP, signal.SIGTERM, signal.SIGKILL):
+        # Windows has no SIGHUP; start with SIGTERM there.
+        _sigs = (
+            (signal.SIGHUP, signal.SIGTERM, signal.SIGKILL)
+            if hasattr(signal, "SIGHUP")
+            else (signal.SIGTERM, signal.SIGKILL)
+        )
+        for sig in _sigs:
             if not self._proc.isalive():
                 break
             try:
